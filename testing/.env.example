# Environment Configuration

# App Settings
ENVIRONMENT=dev
DEBUG=False
APP_NAME=devops-automation
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devdb

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Container Registry
ECR_REGISTRY=your-account-id.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY=devops-automation-app

# ECS
ECS_CLUSTER=devops-automation-cluster
ECS_SERVICE=devops-automation-service

# Monitoring
LOG_LEVEL=INFO
